{
  "name": "openmemory",
  "version": "0.1.0",
  "description": "Open source AI memory engine. Universal memory layer for Claude, ChatGPT, Cursor, and any AI tool.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openmemory": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts serve",
    "mcp": "bun run src/index.ts mcp",
    "test": "bun test",
    "bench": "bun run tests/benchmark.ts",
    "build": "tsc",
    "start": "node dist/index.js serve"
  },
  "keywords": ["ai", "memory", "knowledge-graph", "mcp", "claude", "llm", "vector-search"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndroidPoet/openmemory"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "hono": "^4.12.7",
    "nanoid": "^5.1.6",
    "sqlite-vec": "^0.1.7-alpha.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
