{
  "name": "openmemory-ai",
  "version": "0.1.0",
  "description": "Open source AI memory engine. Universal memory layer for Claude, ChatGPT, Cursor, and any AI tool.",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "openmemory": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts serve",
    "mcp": "bun run src/index.ts mcp",
    "test": "bun test",
    "bench": "bun run tests/benchmark.ts",
    "build": "tsc",
    "start": "bun run src/index.ts serve"
  },
  "keywords": ["ai", "memory", "knowledge-graph", "mcp", "claude", "chatgpt", "cursor", "llm", "vector-search", "bm25", "rag"],
  "author": "Ranbir Singh <androidpoet@gmail.com> (https://github.com/AndroidPoet)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndroidPoet/openmemory"
  },
  "homepage": "https://github.com/AndroidPoet/openmemory#readme",
  "bugs": {
    "url": "https://github.com/AndroidPoet/openmemory/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "os": ["darwin", "linux", "win32"],
  "files": [
    "src/**/*",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "hono": "^4.12.7",
    "nanoid": "^5.1.6",
    "sqlite-vec": "^0.1.7-alpha.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
